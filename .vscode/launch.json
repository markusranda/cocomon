  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug game",
          "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/cocomon",
      "osx": {
        "MIMode": "lldb"
      },
      "linux": {
        "program": "${workspaceFolder}/build/cocomon",
        "MIMode": "gdb"
      },
      "windows": {
        "program": "${workspaceFolder}/build/Debug/cocomon.exe"
      },
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "build-cocomon"
    }
  ]
}
